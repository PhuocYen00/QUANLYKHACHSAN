@{
    ViewBag.Title = "ABC Booking Hotel Khách sạn hàng đầu Việt Nam";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<header id="gtco-header" class="gtco-cover gtco-cover-md" role="banner" style="background-image: url(/Content/Home/images/img_bg_4.jpg); height: 600px; padding-top: 50px; padding-bottom: 50px;" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="gtco-container" style="max-width: 900px; margin: 0 auto;">
        <div class="row">
            <div class="col-md-12 col-md-offset-0 text-left">
                <div class="row" style="margin-top: 8em;">
                    <div class="col-md-7 mt-text animate-box" data-animate-effect="fadeInUp">
                        <span class="intro-text-small">Khách sạn đạt chuẩn 5 sao tại Việt Nam !</span>
                        <h1 class="cursive-font" style="font-size: 60px;">The best 5 star hotel in VietNam!</h1>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<div class="gtco-section">
    <div class="gtco-container">
        @*  *@
        <div class="form-wrap">
            <div class="tab">
                <div class="tab-content">
                    <div class="tab-content-inner active" data-content="signup">
                        <h3 class="cursive-font">Tìm phòng</h3>
                        @using (Html.BeginForm("FindRoom", "Home"))
                        {
                            <div class="row form-group">
                                <div class="col-md-6">
                                    <label for="date_start">Ngày nhận phòng</label>
                                    @Html.TextBox("datestart", null, new { @class = "form-control" })
                                </div>
                                <div class="col-md-6">
                                    <label for="date_end">Ngày trả phòng</label>
                                    @Html.TextBox("dateend", null, new { @class = "form-control" })
                                </div>
                            </div>

                            <div class="row form-group">
                                <div class="col-md-12">
                                    <input type="submit" onclick="return checkday()" class="btn btn-primary btn-block" value="Đặt Ngay">
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        @*  *@
        <div class="row">
            <div class="col-md-8 col-md-offset-2 text-center gtco-heading">
                <h2 class="cursive-font primary-color">Thông tin</h2>
                <p>ABC Booking Hotel tọa lạc tại trung tâm thành phố Thủ Dầu Một, Bình Dương. Mang đến cho khách hàng không gian nghỉ dưỡng thoải mái và tiện nghi.</p>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-4 col-md-4 col-sm-6">
                <a href="~/Content/Home/images/img_1.jpg" class="fh5co-card-item image-popup">
                    <figure>
                        <div class="overlay"><i class="ti-plus"></i></div>
                        <img src="~/Content/Home/images/img_1.jpg" alt="Image" class="img-responsive" style="max-width: 100%; height: auto;">
                    </figure>
                    <div class="fh5co-text">
                        <h2>Phòng ở</h2>
                        <p>Khách sạn ABC - Hotel với nhiều phòng có sức chứa khác nhau, đáp ứng từng yêu cầu của quý khách hàng.</p>
                        <p><span class="price cursive-font"></span></p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-4 col-sm-6">
                <a href="~/Content/Home/images/img_2.jpg" class="fh5co-card-item image-popup">
                    <figure>
                        <div class="overlay"><i class="ti-plus"></i></div>
                        <img src="~/Content/Home/images/img_2.jpg" alt="Image" class="img-responsive" style="max-width: 100%; height: auto;">
                    </figure>
                    <div class="fh5co-text">
                        <h2>Không gian</h2>
                        <p>Từ khách sạn Quý khách có thể bao quát được toàn cảnh trung tâm thành phố với những tòa nhà cao tầng, đường xá phố thị</p>
                        <p><span class="price cursive-font"></span></p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-4 col-sm-6">
                <a href="~/Content/Home/images/img_3.jpg" class="fh5co-card-item image-popup">
                    <figure>
                        <div class="overlay"><i class="ti-plus"></i></div>
                        <img src="~/Content/Home/images/img_3.jpg" alt="Image" class="img-responsive" style="max-width: 100%; height: auto;">
                    </figure>
                    <div class="fh5co-text">
                        <h2>Trải nghiệm</h2>
                        <p>Là địa điểm lý tưởng để quý khách lưu lại trong những chuyến công tác dài ngày hoặc để cảm nhận 1 cảm giác khác biệt ngay trong thành phố.</p>
                        <p><span class="price cursive-font"></span></p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-4 col-sm-6">
                <a href="~/Content/Home/images/img_4.jpg" class="fh5co-card-item image-popup">
                    <figure>
                        <div class="overlay"><i class="ti-plus"></i></div>
                        <img src="~/Content/Home/images/img_4.jpg" alt="Image" class="img-responsive" style="max-width: 100%; height: auto;">
                    </figure>
                    <div class="fh5co-text">
                        <h2>Quầy bar</h2>
                        <p>Quầy bar của khách sạn ABC Booking Hotel nằm ngay tại sảnh khách sạn, là một lựa chọn thú vị cho những ai yêu thích sự sôi động và ấm cúng.</p>
                        <p><span class="price cursive-font"></span></p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-4 col-sm-6">
                <a href="~/Content/Home/images/img_5.jpg" class="fh5co-card-item image-popup">
                    <figure>
                        <div class="overlay"><i class="ti-plus"></i></div>
                        <img src="~/Content/Home/images/img_5.jpg" alt="Image" class="img-responsive" style="max-width: 100%; height: auto;">
                    </figure>
                    <div class="fh5co-text">
                        <h2>Ẩm thực</h2>
                        <p>Chắc chắn quý khách sẽ rất hài lòng vì chính nét ẩm thực được chú trọng đến từng chi tiết, từng hương vị.</p>
                        <p><span class="price cursive-font"></span></p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-4 col-sm-6">
                <a href="~/Content/Home/images/img_6.jpg" class="fh5co-card-item image-popup">
                    <figure>
                        <div class="overlay"><i class="ti-plus"></i></div>
                        <img src="~/Content/Home/images/img_6.jpg" alt="Image" class="img-responsive" style="max-width: 100%; height: auto;">
                    </figure>
                    <div class="fh5co-text">
                        <h2>Tuyệt vời</h2>
                        <p>Đó có thể là bữa sáng cùng gia đình hoặc đối tác, là những bữa ăn trưa cùng đồng nghiệp hay những buổi tối nhâm nhi cùng bạn bè hoặc người yêu.</p>
                        <p><span class="price cursive-font"></span></p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>
<div id="gtco-counter" class="gtco-section" style="background-color: #cec5c5">
    <div class="gtco-container">

        <div class="row">
            <div class="col-md-8 col-md-offset-2 text-center gtco-heading animate-box">
                <h2 class="cursive-font primary-color">Điểm nổi bậc</h2>
            </div>
        </div>
        <div class="row">

            <div class="col-md-3 col-sm-6 animate-box" data-animate-effect="fadeInUp">
                <div class="feature-center">
                    <span class="counter js-counter" data-from="0" data-to="1000" data-speed="5000" data-refresh-interval="50">1</span>
                    <span class="counter-label">Lượt xếp hạng đánh giá</span>

                </div>
            </div>
            <div class="col-md-3 col-sm-6 animate-box" data-animate-effect="fadeInUp">
                <div class="feature-center">
                    <span class="counter js-counter" data-from="0" data-to="48" data-speed="5000" data-refresh-interval="50">1</span>
                    <span class="counter-label">Phòng</span>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 animate-box" data-animate-effect="fadeInUp">
                <div class="feature-center">
                    <span class="counter js-counter" data-from="0" data-to="72" data-speed="5000" data-refresh-interval="50">1</span>
                    <span class="counter-label">Loại ẩm thực</span>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 animate-box" data-animate-effect="fadeInUp">
                <div class="feature-center">
                    <span class="counter js-counter" data-from="0" data-to="2020" data-speed="5000" data-refresh-interval="50">1</span>
                    <span class="counter-label">Năm bắt đầu hoạt động</span>

                </div>
            </div>

        </div>
    </div>
</div>

<script>
    function checkday() {
        var from1 = $("#datestart").val().split("/");
        var dateS = new Date(from1[2], from1[1] - 1, from1[0]);
        var from2 = $("#dateend").val().split("/");
        var dateE = new Date(from2[2], from2[1] - 1, from2[0]);

        var now = new Date();
        now.setHours(0);
        now.setSeconds(0);
        now.setMinutes(0);
        now.setMilliseconds(0);

        if (dateS < now) {
            alert("Ngày vào lớn hơn hoặc bằng ngày hiện tại !");
            return false;
        }
        if (dateE <= dateS) {
            alert("Ngày ra phải lớn hơn ngày vào ít nhất 1 ngày !");
            return false;
        }
        if (from1 == "" || from2 == "") {
            alert("Ngày tháng không được để trống !");
            return false;
        }
        return true;
    }
</script>